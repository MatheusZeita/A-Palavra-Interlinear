  "notas": [
    {
      "id": "n1",
      "versiculo": 1,
      "negrito": "τις",
      "texto": "Pronome feminino. Concorda com παράκλησις (encorajamento)."
    },
    {
      "id": "n2",
      "versiculo": 1,
      "negrito": "παράκλησις",
      "texto": "Ou, possivelmente: “exortação; consolo”; Transliteração: “paráclesis”."
    },
    {
      "id": "n3",
      "versiculo": 1,
      "negrito": "Χριστῷ,",
      "texto": "Transliteração: “Cristo”."
    },
    {
      "id": "n4",
      "versiculo": 1,
      "negrito": "τις",
      "texto": "Pronome feminino. Concorda com κοινωνία (compartilhamento)."
    },
    {
      "id": "n5",
      "versiculo": 1,
      "negrito": "σπλάγχνα",
      "texto": "Ou: “[sentimentos] viscerais”; Isto é: “ternos sentimentos”. Refere-se literalmente às entranhas de uma pessoa e figurativamente a sentimentos profundos e emoções intensas."
    },
    {
      "id": "n6",
      "versiculo": 2,
      "negrito": "πληρώσατέ",
      "texto": "Ou: “completem”."
    },
    {
      "id": "n7",
      "versiculo": 2,
      "negrito": "τὴν",
      "texto": "Artigo feminino. Concorda com “ἀγάπην” (amor)."
    },
    {
      "id": "n8",
      "versiculo": 2,
      "negrito": "σύμψυχοι,",
      "texto": "Isto é: “plenamente unidos”."
    },
    {
      "id": "n9",
      "versiculo": 3,
      "negrito": "κενοδοξίαν,",
      "texto": "Ou: “presunção; vaidade”."
    },
    {
      "id": "n10",
      "versiculo": 4,
      "negrito": "σκοποῦντες,",
      "texto": "Ou: “atentando; tendo em vista; considerando”."
    },
    {
      "id": "n11",
      "versiculo": 6,
      "negrito": "ἁρπαγμὸν",
      "texto": "Ou: “usurpação”. Derivada do verbo “ἁρπάζω”, que significa “usurpar; arrancar; apoderar-se”."
    },
    {
      "id": "n12",
      "versiculo": 9,
      "negrito": "ἐχαρίσατο",
      "texto": "Ou: “concedeu”. Relacionada à palavra grega para “graça; favor; bondade”."
    },
    {
      "id": "n13",
      "versiculo": 9,
      "negrito": "τὸ",
      "texto": "Alguns manuscritos, especialmente bizantinos, omitem este artigo."
    },
    {
      "id": "n14",
      "versiculo": 11,
      "negrito": "ἐξομολογήσηται",
      "texto": "Ou: “declare publicamente; confesse”."
    },
    {
      "id": "n15",
      "versiculo": 11,
      "negrito": "Χριστὸς",
      "texto": "Alguns manuscritos, especialmente ocidentais, omitem esta palavra."
    },
    {
      "id": "n16",
      "versiculo": 12,
      "negrito": "φόβου",
      "texto": "Ou: “temor; reverência”."
    }
  ]
}
